# Stage 1: Download and verify bd binary
FROM registry.access.redhat.com/ubi9/ubi-minimal AS fetcher

ARG BEADS_VERSION=0.60.0

RUN microdnf install -y tar gzip && \
    microdnf clean all

RUN cd /tmp && \
    curl -fsSL "https://github.com/gastownhall/beads/releases/download/v${BEADS_VERSION}/beads_${BEADS_VERSION}_linux_amd64.tar.gz" -o "beads_${BEADS_VERSION}_linux_amd64.tar.gz" && \
    curl -fsSL "https://github.com/gastownhall/beads/releases/download/v${BEADS_VERSION}/checksums.txt" -o checksums.txt && \
    grep "beads_${BEADS_VERSION}_linux_amd64.tar.gz" checksums.txt | sha256sum -c - && \
    tar xzf "beads_${BEADS_VERSION}_linux_amd64.tar.gz" && \
    chmod +x /tmp/bd

# Stage 2: Final runtime image
FROM registry.access.redhat.com/ubi9/ubi-minimal

LABEL org.opencontainers.image.source="https://github.com/ambient-code/beads-acp" \
      org.opencontainers.image.description="beads-mcp server with mcp-proxy and bd CLI" \
      org.opencontainers.image.version="0.60.0"

RUN microdnf install -y python3.11 python3.11-pip && \
    python3.11 -m pip install --no-cache-dir uv && \
    uv pip install --system --python python3.11 beads-mcp mcp-proxy==0.11.0 && \
    microdnf clean all

COPY --from=fetcher /tmp/bd /usr/local/bin/bd

RUN useradd -u 1001 -g 0 -M -d /home/beads -s /usr/sbin/nologin beads && \
    mkdir -p /home/beads && \
    chown -R 1001:0 /home/beads && \
    chmod -R g=u /home/beads

USER 1001
WORKDIR /home/beads

ENTRYPOINT ["beads-mcp"]
